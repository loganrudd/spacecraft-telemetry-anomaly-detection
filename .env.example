# Environment: local | cloud | test
SPACECRAFT_ENV=local

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# GCP credentials (local dev only — use Workload Identity on Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCP project (required for cloud env)
# GCP_PROJECT=your-gcp-project-id

# GCS bucket names (required for cloud env)
# GCS_BUCKET_RAW=your-project-raw-data
# GCS_BUCKET_PROCESSED=your-project-processed
# GCS_BUCKET_ARTIFACTS=your-project-artifacts

# MLflow tracking URI (defaults to local SQLite in local env)
# MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db
